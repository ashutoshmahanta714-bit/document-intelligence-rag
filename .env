# LLM Provider (OpenAI or compatible)
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-3.5-turbo

# Optional: Use local Ollama instead of OpenAI
# OPENAI_API_KEY=ollama
# LLM_MODEL=llama3
# OPENAI_BASE_URL=http://localhost:11434/v1

# Server config
HOST=0.0.0.0
PORT=8000
